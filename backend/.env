# --- APP CORE ---
PROJECT_NAME="OneRx Connect"
ENVIRONMENT=development
DEBUG=true
PORT=8000
SECRET_KEY=generate_this_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=fern_key_for_pii_data

# --- DATABASE ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/onerx
REDIS_URL=redis://localhost:6379/0

# --- TELCO & SIP ---
TELNYX_API_KEY=your_telnyx_api_key
TELNYX_SIP_PASSWORD=your_telnyx_sip_password
FREESWITCH_ESL_HOST=127.0.0.1
FREESWITCH_ESL_PORT=8021
FREESWITCH_ESL_PASSWORD=ClueCon
KAMAILIO_DB_URL=postgresql://postgres:postgres@localhost:5432/kamailio

# --- AI SERVICES ---
DEEPGRAM_API_KEY=your_deepgram_api_key
OPENAI_API_KEY=your_openai_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# --- BILLING (STRIPE) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLIC_KEY=pk_test_...

# --- STORAGE (AWS S3) ---
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=onerx-recordings
AWS_REGION=ca-central-1

# --- CRM ---
HUBSPOT_CLIENT_ID=your_hubspot_id
HUBSPOT_CLIENT_SECRET=your_hubspot_secret
SALESFORCE_CLIENT_ID=your_sf_id
SALESFORCE_CLIENT_SECRET=your_sf_secret

# --- COMPLIANCE ---
CANADA_DATA_RESIDENCY=true
RETENTION_YEARS=7
HEALTHCARE_COMPLIANT=true
